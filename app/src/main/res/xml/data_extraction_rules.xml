<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude encrypted API-key storage from cloud restore. -->
        <exclude domain="sharedpref" path="nanogpt_secure_settings.xml" />
    </cloud-backup>
    <device-transfer>
        <!-- Exclude encrypted API-key storage from device-to-device transfer restores too. -->
        <exclude domain="sharedpref" path="nanogpt_secure_settings.xml" />
    </device-transfer>
</data-extraction-rules>
